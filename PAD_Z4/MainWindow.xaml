<Window x:Class="PAD_Z4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PAD_Z4 - Kalkulator"
        Height="720"
        Width="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1F2428">

    <Window.Resources>

        <!-- Styl cyfr -->
        <Style x:Key="NumButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="#A8B0B8"
                                CornerRadius="12">

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Opacity"
                                        Value="0.85"/>
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Opacity"
                                        Value="0.65"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Styl operatorów -->
        <Style x:Key="OperatorButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource NumButtonStyle}">

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                                Background="#B66A3C"
                                CornerRadius="12">

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Opacity"
                                        Value="0.85"/>
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Opacity"
                                        Value="0.65"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Styl funkcji -->
        <Style x:Key="FunctionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource NumButtonStyle}">

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                                Background="#3B434A"
                                CornerRadius="12">

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Opacity"
                                        Value="0.85"/>
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Opacity"
                                        Value="0.65"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="180"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- WYŚWIETLACZ -->
        <Border Grid.Row="0"
                Background="#2B223B"
                CornerRadius="20"
                Margin="5">

            <StackPanel VerticalAlignment="Center">

                <TextBlock x:Name="ExpressionLabel"
                           Text=""
                           FontSize="22"
                           Foreground="#A8B0B8"
                           HorizontalAlignment="Right"
                           Margin="0,20,20,0"/>

                <TextBlock x:Name="DisplayLabel"
                           Text="0"
                           FontSize="52"
                           FontWeight="Bold"
                           Foreground="#C084FC"
                           HorizontalAlignment="Right"
                           Margin="0,20,20,20"/>

            </StackPanel>
        </Border>

        <!-- KLAWIATURA -->
        <Grid Grid.Row="1">

            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- Wiersz 1 -->
            <Button Grid.Row="0" Grid.Column="0"
                    Content="C"
                    Click="BtnClear_Click"
                    Style="{StaticResource FunctionButtonStyle}"/>

            <Button Grid.Row="0" Grid.Column="1"
                    Content="CE"
                    Click="BtnClearEntry_Click"
                    Style="{StaticResource FunctionButtonStyle}"/>

            <Button Grid.Row="0" Grid.Column="2"
                    Content="+/-"
                    Click="BtnPlusMinus_Click"
                    Style="{StaticResource FunctionButtonStyle}"/>

            <Button Grid.Row="0" Grid.Column="3"
                    Content="%"
                    Click="BtnPercent_Click"
                    Style="{StaticResource OperatorButtonStyle}"/>

            <!-- Wiersz 2 -->
            <Button Grid.Row="1" Grid.Column="0"
                    Content="1/x"
                    Click="BtnInverse_Click"
                    Style="{StaticResource FunctionButtonStyle}"/>

            <Button Grid.Row="1" Grid.Column="1"
                    Content="x^2"
                    Click="BtnSquare_Click"
                    Style="{StaticResource FunctionButtonStyle}"/>

            <Button Grid.Row="1" Grid.Column="2"
                    Content="&#x221A;"
                    Click="BtnSqrt_Click"
                    Style="{StaticResource FunctionButtonStyle}"/>

            <Button Grid.Row="1" Grid.Column="3"
                    Content="÷"
                    Tag="÷"
                    Click="BtnOperator_Click"
                    Style="{StaticResource OperatorButtonStyle}"/>

            <!-- Wiersz 3 -->
            <Button Grid.Row="2" Grid.Column="0"
                    Content="7"
                    Click="BtnDigit_Click"
                    Style="{StaticResource NumButtonStyle}"/>

            <Button Grid.Row="2" Grid.Column="1"
                    Content="8"
                    Click="BtnDigit_Click"
                    Style="{StaticResource NumButtonStyle}"/>

            <Button Grid.Row="2" Grid.Column="2"
                    Content="9"
                    Click="BtnDigit_Click"
                    Style="{StaticResource NumButtonStyle}"/>

            <Button Grid.Row="2" Grid.Column="3"
                    Content="×"
                    Tag="×"
                    Click="BtnOperator_Click"
                    Style="{StaticResource OperatorButtonStyle}"/>

            <!-- Wiersz 4 -->
            <Button Grid.Row="3" Grid.Column="0"
                    Content="4"
                    Click="BtnDigit_Click"
                    Style="{StaticResource NumButtonStyle}"/>

            <Button Grid.Row="3" Grid.Column="1"
                    Content="5"
                    Click="BtnDigit_Click"
                    Style="{StaticResource NumButtonStyle}"/>

            <Button Grid.Row="3" Grid.Column="2"
                    Content="6"
                    Click="BtnDigit_Click"
                    Style="{StaticResource NumButtonStyle}"/>

            <Button Grid.Row="3" Grid.Column="3"
                    Content="-"
                    Tag="-"
                    Click="BtnOperator_Click"
                    Style="{StaticResource OperatorButtonStyle}"/>

            <!-- Wiersz 5 -->
            <Button Grid.Row="4" Grid.Column="0"
                    Content="1"
                    Click="BtnDigit_Click"
                    Style="{StaticResource NumButtonStyle}"/>

            <Button Grid.Row="4" Grid.Column="1"
                    Content="2"
                    Click="BtnDigit_Click"
                    Style="{StaticResource NumButtonStyle}"/>

            <Button Grid.Row="4" Grid.Column="2"
                    Content="3"
                    Click="BtnDigit_Click"
                    Style="{StaticResource NumButtonStyle}"/>

            <Button Grid.Row="4" Grid.Column="3"
                    Content="+"
                    Tag="+"
                    Click="BtnOperator_Click"
                    Style="{StaticResource OperatorButtonStyle}"/>

            <!-- Wiersz 6 -->
            <Button Grid.Row="5" Grid.Column="0"
                    Content="x^y"
                    Tag="x^y"
                    Click="BtnOperator_Click"
                    Style="{StaticResource FunctionButtonStyle}"/>

            <Button Grid.Row="5" Grid.Column="1"
                    Content="0"
                    Click="BtnDigit_Click"
                    Style="{StaticResource NumButtonStyle}"/>

            <Button Grid.Row="5" Grid.Column="2"
                    Content=","
                    Click="BtnComma_Click"
                    Style="{StaticResource NumButtonStyle}"/>

            <Button Grid.Row="5" Grid.Column="3"
                    Content="="
                    Click="BtnEquals_Click"
                    Style="{StaticResource OperatorButtonStyle}"/>
        </Grid>

    </Grid>
</Window>

